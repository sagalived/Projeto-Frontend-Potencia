# Sienge ERP - API credentials
# Copy this file to .env and fill in your values

VITE_SIENGE_SUBDOMAIN=seu-subdominio
VITE_SIENGE_ACCESS_NAME=usuario-acesso-api
VITE_SIENGE_TOKEN=token-api-sienge

# Optional: override the full base URL
# VITE_SIENGE_BASE_URL=https://api.sienge.com.br/seu-subdominio/public/api/v1

# Sync script environment variables (used by node scripts/sync-sienge.mjs)
# SIENGE_SUBDOMAIN=seu-subdominio
# SIENGE_API_USER=usuario-acesso-api
# SIENGE_API_PASSWORD=token-api-sienge
# SIENGE_START_DATE=2026-01-01
